# QUALITTEST - Environment Variables Template
# Copy this file to .env and fill with your values

# Database Configuration
DB_HOST=localhost
DB_USER=qualittest_user
DB_PASSWORD=qualittest_password
DB_NAME=qualittest_system
DB_PORT=3306

# MySQL Root Password (for Docker)
MYSQL_ROOT_PASSWORD=root123
MYSQL_USER=qualittest_user
MYSQL_PASSWORD=qualittest_password

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=qualittest_jwt_secret_key_CHANGE_THIS_IN_PRODUCTION
JWT_EXPIRE=7d

# Frontend Configuration (for development)
REACT_APP_API_URL=http://localhost:5001/api

# Production Variables (uncomment and fill when deploying)
# These will be provided by your hosting platform (Railway, Render, etc.)
# DATABASE_URL=
# JWT_SECRET_PROD=
